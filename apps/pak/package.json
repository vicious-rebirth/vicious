{
  "name": "@repo/pak",
  "version": "0.0.0",
  "description": "Tools to dump/build data.pak files for the Vicious Engine",
  "scripts": {
    "setup:release": "cmake -S . -B build",
    "setup:debug": "cmake -DCMAKE_BUILD_TYPE=Debug -S . -B build",
