{
  "name": "@repo/cli",
  "version": "0.0.0",
  "description": "CLI tools for Vicious Engine",
  "scripts": {
    "build": "rollup --configPlugin @rollup/plugin-typescript --bundleConfigAsCjs -c rollup.config.ts",
    "convert": "tsx src/convert.ts",
    "convert:debug": "tsx --inspect-brk src/convert.ts"
  },
  "license": "MIT",
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.0.3",
    "rollup": "^4.53.5",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@repo/js": "workspace:*"
  }
}
