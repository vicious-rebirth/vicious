{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "codegen": {
      "dependsOn": ["^codegen"]
    },
    "setup:release": {
      "dependsOn": ["^setup:release"]
    },
    "setup:debug": {
      "dependsOn": ["^setup:debug"]
    },
    "setup:web": {
      "dependsOn": ["^setup:web"]
    },
    "build:docs": {
      "dependsOn": ["^build:docs"]
    },
    "build:exe": {
      "dependsOn": ["^build:exe"]
    },
    "build:lib": {
      "dependsOn": ["^build:lib"]
    },
    "build:web": {
      "dependsOn": ["^build:web"]
    }
  }
}
