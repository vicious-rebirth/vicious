{
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "printWidth": 80,
  "trailingComma": "es5",
  "tabWidth": 2,
  "semi": true,
  "singleQuote": false,
  "importOrder": [
    "^.*\\.(css|scss)$",
    "<THIRD_PARTY_MODULES>",
    "^([./]|@repo)"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
